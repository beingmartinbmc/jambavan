# Jambavan Environment (optional — all values have defaults)

# Absolute path to the project root Jambavan should index and serve.
# Default: auto-detected by walking up from cwd looking for package.json / .git
# JAMBAVAN_ROOT=/path/to/your/project

# Token budget for jambavan_context results.
# The context assembler hard-caps output to this many tokens.
# Default: 8000
# JAMBAVAN_TOKEN_BUDGET=8000
