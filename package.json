{
  "name": "jambavan",
  "version": "0.5.0",
  "license": "MIT",
  "description": "Jambavan — an MCP server that awakens any coding model's latent powers: live code index, precise context, durable memory, a code knowledge graph, prompt compression, and guarded file/shell tools.",
  "main": "dist/index.js",
  "bin": {
    "jambavan": "dist/index.js"
  },
  "files": [
    "dist",
    "ARCHITECTURE.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "code-index",
    "tree-sitter",
    "developer-tools"
  ],
  "engines": {
    "node": ">=20 <27"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "docs-check": "node scripts/check-doc-tools.js",
    "self-check": "npm run build && node dist/self-check.js",
    "bench": "npm run build && node dist/benchmark.js",
    "tool-check": "npm run build && node dist/tool-check.js",
    "unit": "node --require ts-node/register --test test/*.test.ts",
    "coverage": "node --require ts-node/register --experimental-test-coverage --test-coverage-include='src/context/token-counter.ts' --test-coverage-include='src/index/ast-parser.ts' --test-coverage-include='src/index/indexer.ts' --test-coverage-include='src/knowledge/graph.ts' --test-coverage-include='src/memory/store.ts' --test-coverage-include='src/tools/bash.ts' --test-coverage-include='src/tools/review-pack.ts' --test-coverage-include='src/tools/memory-bridge.ts' --test-coverage-include='src/tools/pr-handoff.ts' --test-coverage-include='src/tools/daemon.ts' --test-coverage-include='src/tools/gui.ts' --test-coverage-include='src/tools/path-guard.ts' --test-coverage-include='src/tools/read-file.ts' --test-coverage-include='src/tools/registry.ts' --test-coverage-include='src/tools/sankshipta.ts' --test-coverage-include='src/tools/write-file.ts' --test-coverage-lines=90 --test test/*.test.ts",
    "test": "npm run unit && npm run self-check && npm run tool-check",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.11.1",
    "chokidar": "5.0.0",
    "glob": "13.0.6",
    "ignore": "7.0.5",
    "js-tiktoken": "1.0.21",
    "tree-sitter": "0.21.1",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-python": "0.23.4",
    "tree-sitter-rust": "0.23.1",
    "tree-sitter-typescript": "0.23.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.0.1",
    "ts-node": "10.9.2",
    "typescript": "^5.5.3"
  },
  "author": "beingmartinbmc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beingmartinbmc/jambavan.git"
  },
  "homepage": "https://github.com/beingmartinbmc/jambavan#readme",
  "bugs": {
    "url": "https://github.com/beingmartinbmc/jambavan/issues"
  }
}
