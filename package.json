{
  "name": "jambavan",
  "version": "0.6.1",
  "mcpName": "io.github.beingmartinbmc/jambavan",
  "license": "MIT",
  "description": "Local-first MCP memory and code intelligence that helps coding agents recall repo context, decisions, failures, and review impact.",
  "main": "dist/index.js",
  "bin": {
    "jambavan": "dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "assets/30-second-demo.gif",
    "assets/30-second-demo.svg",
    "assets/usage-screenshot.svg",
    "assets/gui-screenshot.svg",
    "examples",
    "server.json",
    ".github/social-preview.png",
    "ARCHITECTURE.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "code-index",
    "tree-sitter",
    "developer-tools",
    "mcp-server",
    "llm-memory",
    "coding-agents",
    "persistent-memory",
    "prompt-compression",
    "codebase-index",
    "local-first",
    "review-automation",
    "agent-memory",
    "claude-code",
    "cursor",
    "codex",
    "code-intelligence",
    "failure-memory",
    "review-pack"
  ],
  "engines": {
    "node": ">=20.19.0 <27"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "docs-check": "node scripts/check-doc-tools.js",
    "installer-check": "node scripts/check-installers.js",
    "self-check": "npm run build && node dist/self-check.js",
    "bench": "npm run build && node dist/benchmark.js",
    "tool-check": "npm run build && node dist/tool-check.js",
    "unit": "node --require ts-node/register --test test/*.test.ts",
    "coverage": "node --require ts-node/register --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-lines=80 --test-coverage-branches=75 --test-coverage-functions=75 --test test/*.test.ts",
    "test": "npm run unit && npm run self-check && npm run tool-check",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.11.1",
    "chokidar": "5.0.0",
    "glob": "13.0.6",
    "ignore": "7.0.5",
    "js-tiktoken": "1.0.21",
    "tree-sitter": "0.21.1",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-python": "0.23.4",
    "tree-sitter-rust": "0.23.1",
    "tree-sitter-typescript": "0.23.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.0.1",
    "ts-node": "10.9.2",
    "typescript": "^5.5.3"
  },
  "author": "beingmartinbmc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beingmartinbmc/jambavan.git"
  },
  "homepage": "https://github.com/beingmartinbmc/jambavan#readme",
  "bugs": {
    "url": "https://github.com/beingmartinbmc/jambavan/issues"
  },
  "directories": {
    "example": "examples",
    "test": "test"
  },
  "type": "commonjs",
  "types": "./dist/index.d.ts"
}
